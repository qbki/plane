{
  "version": 6,
  "include": ["./ConanPresets.json"],
  "configurePresets": [
    {
      "name": "x86_64-linux-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "inherits": "conan-release",
      "toolchainFile": "./build/Release/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x86_64-linux-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "./build/Debug/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x86_64-linux-release",
      "configurePreset": "x86_64-linux-release"
    },
    {
      "name": "x86_64-linux-debug",
      "configurePreset": "x86_64-linux-debug"
    }
  ]
}

